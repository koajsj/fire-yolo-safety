# 消防安全行为检测 - 数据集配置示例（YOLO 格式）
# 训练前请根据实际数据集路径修改，并保存为 data.yaml
#
# 目录结构建议：
# dataset/
#   images/
#     train/   训练图片
#     val/     验证图片
#   labels/
#     train/   训练标注（与图片同名 .txt）
#     val/     验证标注

# 数据集根目录（绝对路径或相对 train.py 的路径）
path: D:/dataset/fire_safety

train: images/train
val: images/val

# 类别数量
nc: 4

# 类别名称（顺序即类别 id，消防安全场景）
names:
  0: fire      # 火焰
  1: smoke     # 烟雾
  2: smoking   # 抽烟
  3: person    # 人员
