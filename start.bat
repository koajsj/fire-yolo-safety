@echo off
chcp 65001 >nul
REM ============================================================
REM 消防安全风险分析与预警系统 - Windows 一键启动脚本
REM 同时启动后端(FastAPI) 与 前端(Vite)
REM ============================================================

setlocal
set ROOT=%~dp0

echo ============================================================
echo   消防安全风险分析与预警系统 启动中...
echo ============================================================

REM ---------- 启动后端 ----------
echo [1/2] 启动后端服务 (http://127.0.0.1:8000) ...
start "fire-backend" cmd /k "cd /d %ROOT%backend && python -m uvicorn main:app --host 127.0.0.1 --port 8000"

REM 等待后端初始化
timeout /t 3 /nobreak >nul

REM ---------- 启动前端 ----------
echo [2/2] 启动前端服务 (http://127.0.0.1:5173) ...
start "fire-frontend" cmd /k "cd /d %ROOT%frontend && npm run dev"

echo.
echo ============================================================
echo   启动完成！
echo   前端访问地址: http://127.0.0.1:5173
echo   后端接口文档: http://127.0.0.1:8000/docs
echo   无需登录，打开前端地址即可直接使用
echo ============================================================
echo.
echo 关闭本窗口不会停止服务，请分别关闭弹出的两个命令行窗口以停止。
pause
endlocal
